# ============================================
# TrustFix Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# --------------------------------------------
# Django Core Settings
# --------------------------------------------
DEBUG=True
SECRET_KEY=your-django-secret-key-change-this-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,*.railway.app

# --------------------------------------------
# Database Configuration
# --------------------------------------------

# Set to True to use Supabase PostgreSQL, False for local SQLite
USE_SUPABASE=False

# Supabase PostgreSQL (required when USE_SUPABASE=True)
# Get from: Supabase Dashboard → Settings → Database → Connection String
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.xxxxxxxxxxxxxxxxxxxx
SUPABASE_DB_PASSWORD=your_supabase_db_password
SUPABASE_DB_HOST=aws-0-xxxxx.pooler.supabase.com
SUPABASE_DB_PORT=5432

# Alternative: Direct DATABASE_URL (overrides above if set)
# DATABASE_URL=postgresql://user:password@host:port/database

# --------------------------------------------
# Redis (Cache & Celery)
# --------------------------------------------
# Option 1: Local Redis
REDIS_URL=redis://localhost:6379/1

# Option 2: Railway/Cloud Redis
# REDIS_URL=redis://default:password@host:port

# --------------------------------------------
# Razorpay Payments (Required for payments)
# Get from: https://dashboard.razorpay.com/app/keys
# --------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Your Razorpay account number for payouts (found in dashboard)
RAZORPAY_ACCOUNT_NUMBER=xxxxxxxxxxxxxxx

# --------------------------------------------
# Google OAuth (Required for Google login)
# Get from: https://console.cloud.google.com/apis/credentials
# --------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# --------------------------------------------
# AI Services (Required for AI Engine)
# --------------------------------------------

# Groq LLM - For AI Quotes and Text Analysis
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI - For VLM Photo Verification (GPT-4 Vision)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# LangSmith - For AI Monitoring & Tracing (Optional but Recommended)
# Get from: https://smith.langchain.com → Settings → API Keys
# Enable tracing to monitor AI performance, costs, and errors in production
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxx
LANGCHAIN_PROJECT=trustfix-production
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --------------------------------------------
# Database (Alternative: Direct DATABASE_URL)
# --------------------------------------------
DATABASE_URL=postgresql://user:password@host:port/database

# --------------------------------------------
# SMS/OTP Service
# --------------------------------------------
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=TRUSTX

# --------------------------------------------
# Fast2SMS (Legacy - uses SMS_API_KEY)
# --------------------------------------------
# FAST2SMS_API_KEY=your_fast2sms_api_key

# Twilio (Alternative SMS provider)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
# TWILIO_PHONE_NUMBER=+1234567890

# --------------------------------------------
# Firebase (Optional - for push notifications)
# --------------------------------------------
FCM_SERVER_KEY=your_fcm_server_key

# --------------------------------------------
# WhatsApp Business API (Optional - for production)
# Get from: Meta for Developers → WhatsApp Business API
# --------------------------------------------
WHATSAPP_API_TOKEN=your_whatsapp_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# --------------------------------------------
# Firebase (Optional - for push notifications)
# --------------------------------------------
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
# --------------------------------------------
# Cloudinary (Optional - for image uploads)
# --------------------------------------------
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# --------------------------------------------
# Email (Optional - for email notifications)
# --------------------------------------------
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@trustfix.in

# --------------------------------------------
# Frontend URL (for CORS and redirects)
# --------------------------------------------
FRONTEND_URL=http://localhost:3000

# --------------------------------------------
# Celery (Background Tasks)
# --------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# --------------------------------------------
# Feature Flags (Environment-specific toggles)
# --------------------------------------------
ENABLE_AI_QUOTES=False
ENABLE_REALTIME_TRACKING=False
ENABLE_WHATSAPP_NOTIFICATIONS=False
ENABLE_REFERRAL_SYSTEM=False

# --------------------------------------------
# Sentry Error Tracking (Optional - for production)
# --------------------------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# --------------------------------------------
# AWS S3 Storage (Optional - for production)
# --------------------------------------------
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=ap-south-1

# --------------------------------------------
# Apple OAuth (Optional)
# --------------------------------------------
# APPLE_CLIENT_ID=your_apple_client_id
# APPLE_CLIENT_SECRET=your_apple_client_secret
# APPLE_REDIRECT_URI=http://localhost:3000/auth/callback

# --------------------------------------------
# Security (Production only)
# --------------------------------------------
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
